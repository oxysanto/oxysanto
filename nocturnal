local function removeESP(targetPlayer)
    local esp = ESPObjects[targetPlayer]
    if not esp then return end
    
    for _, obj in pairs(esp) do
        if typeof(obj) == "Instance" then
            pcall(function() obj:Destroy() end)
        else
            pcall(function() obj:Remove() end)
        end
    end
    
    ESPObjects[targetPlayer] = nil
end

local function updateESP()
    if not (Toggles.ESPMaster and Toggles.ESPMaster.Value) then
        for _, esp in pairs(ESPObjects) do
            for name, obj in pairs(esp) do
                if typeof(obj) == "Instance" then
                    obj.Enabled = false
                else
                    obj.Visible = false
                end
            end
        end
        return
    end
    
    local maxDist = Options.ESPMaxDistance and Options.ESPMaxDistance.Value or 1000
    local textSize = Options.ESPTextSize and Options.ESPTextSize.Value or 14
    local myChar = player.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    
    for targetPlayer, esp in pairs(ESPObjects) do
        -- Skip allies if option enabled
        if Toggles.ESPIgnoreAllies and Toggles.ESPIgnoreAllies.Value and isAlly(targetPlayer) then
            for name, obj in pairs(esp) do
                if typeof(obj) == "Instance" then
                    obj.Enabled = false
                else
                    obj.Visible = false
                end
            end
            continue
        end
        
        local character = targetPlayer.Character
        local hrp = character and character:FindFirstChild("HumanoidRootPart")
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        local head = character and character:FindFirstChild("Head")
        
        if not (character and hrp and humanoid and head and myHRP) then
            for name, obj in pairs(esp) do
                if typeof(obj) == "Instance" then
                    obj.Enabled = false
                else
                    obj.Visible = false
                end
            end
            continue
        end
        
        local distance = (myHRP.Position - hrp.Position).Magnitude
        if distance > maxDist then
            for name, obj in pairs(esp) do
                if typeof(obj) == "Instance" then
                    obj.Enabled = false
                else
                    obj.Visible = false
                end
            end
            continue
        end
        
        local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
        local headPos = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
        local footPos = camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
        
        if not onScreen then
            for name, obj in pairs(esp) do
                if typeof(obj) == "Instance" then
                    obj.Enabled = false
                else
                    obj.Visible = false
                end
            end
            continue
        end
        
        local boxHeight = math.abs(headPos.Y - footPos.Y)
        local boxWidth = boxHeight * 0.6
        local boxX = screenPos.X - boxWidth / 2
        local boxY = headPos.Y
        
        local health = humanoid.Health
        local maxHealth = humanoid.MaxHealth
        local healthPercent = health / maxHealth
        
        local isLocked = _lockedTarget == targetPlayer or AimlockTarget == targetPlayer
        local isAllyPlayer = isAlly(targetPlayer)
        
        -- Name ESP
        if Toggles.ESPNames and Toggles.ESPNames.Value then
            local nameText = targetPlayer.Name
            if isAllyPlayer then
                nameText = "[ALLY] " .. nameText
            end
            esp.Name.Text = nameText
            esp.Name.Position = Vector2.new(screenPos.X, headPos.Y - 20)
            esp.Name.Size = textSize
            if isAllyPlayer then
                esp.Name.Color = Color3.fromRGB(0, 255, 0)
            else
                esp.Name.Color = Options.ESPNameColor and Options.ESPNameColor.Value or Color3.new(1, 1, 1)
            end
            esp.Name.Visible = true
        else
            esp.Name.Visible = false
        end
        
        -- Distance ESP
        if Toggles.ESPDistance and Toggles.ESPDistance.Value then
            esp.Distance.Text = math.floor(distance) .. "m"
            esp.Distance.Position = Vector2.new(screenPos.X, footPos.Y + 5)
            esp.Distance.Size = textSize
            esp.Distance.Color = Color3.new(1, 1, 1)
            esp.Distance.Visible = true
        else
            esp.Distance.Visible = false
        end
        
        -- Chams
        if Toggles.ESPChams and Toggles.ESPChams.Value then
            esp.Chams.Adornee = character
            if isLocked then
                esp.Chams.FillColor = Options.ChamsLockedColor and Options.ChamsLockedColor.Value or Color3.fromRGB(255, 0, 0)
                esp.Chams.OutlineColor = Options.ChamsLockedColor and Options.ChamsLockedColor.Value or Color3.fromRGB(255, 0, 0)
            elseif isAllyPlayer then
                esp.Chams.FillColor = Color3.fromRGB(0, 255, 0)
                esp.Chams.OutlineColor = Color3.fromRGB(0, 255, 0)
            else
                esp.Chams.FillColor = Options.ChamsColor and Options.ChamsColor.Value or Color3.fromRGB(255, 255, 255)
                esp.Chams.OutlineColor = Options.ChamsColor and Options.ChamsColor.Value or Color3.fromRGB(255, 255, 255)
            end
            
            if Toggles.ThermalChams and Toggles.ThermalChams.Value then
                local thermalColor = Color3.fromHSV(0.7 - (healthPercent * 0.7), 1, 1)
                esp.Chams.FillColor = thermalColor
                esp.Chams.OutlineColor = thermalColor
            end
            
            esp.Chams.Enabled = true
        else
            esp.Chams.Enabled = false
        end
        
        -- Health Bar
        if Toggles.ESPHealthBar and Toggles.ESPHealthBar.Value then
            local barHeight = boxHeight * healthPercent
            local barX = boxX - 5
            
            esp.HealthBarBG.From = Vector2.new(barX, boxY + boxHeight)
            esp.HealthBarBG.To = Vector2.new(barX, boxY)
            esp.HealthBarBG.Visible = true
            
            local healthColor
            if healthPercent > 0.75 then
                healthColor = Options.HealthBarColor1 and Options.HealthBarColor1.Value or Color3.fromRGB(0, 255, 0)
            elseif healthPercent > 0.5 then
                healthColor = Options.HealthBarColor2 and Options.HealthBarColor2.Value or Color3.fromRGB(255, 255, 0)
            elseif healthPercent > 0.25 then
                healthColor = Options.HealthBarColor3 and Options.HealthBarColor3.Value or Color3.fromRGB(255, 165, 0)
