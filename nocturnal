-- ══════ ALLY SYSTEM ══════
local function isAlly(targetPlayer)
    if AllyList[targetPlayer.Name] then return true end
    local allyFolder = player:FindFirstChild("PlayerFolder") and player.PlayerFolder:FindFirstChild("Allied")
    if allyFolder and allyFolder:FindFirstChild(targetPlayer.Name) then return true end
    return false
end

local function addAlly(targetPlayer)
    if targetPlayer == player then return end
    AllyList[targetPlayer.Name] = true
    Library:Notify({Title = "Ally System", Description = targetPlayer.Name .. " added to allies!", Time = 2})
end

local function removeAlly(targetPlayer)
    AllyList[targetPlayer.Name] = nil
    Library:Notify({Title = "Ally System", Description = targetPlayer.Name .. " removed from allies!", Time = 2})
end

local function toggleAlly(targetPlayer)
    if AllyList[targetPlayer.Name] then
        removeAlly(targetPlayer)
    else
        addAlly(targetPlayer)
    end
end

-- ══════ HIT EFFECT SYSTEM ══════
local function createHitEffect(position, effectType)
    if not (Toggles.HitEffect and Toggles.HitEffect.Value) then return end
    
    local effectColor = Options.HitEffectColor and Options.HitEffectColor.Value or Color3.fromRGB(255, 0, 0)
    local effectSize = Options.HitEffectSize and Options.HitEffectSize.Value or 2
    
    if effectType == "Sphere" then
        local part = Instance.new("Part")
        part.Shape = Enum.PartType.Ball
        part.Size = Vector3.new(0.1, 0.1, 0.1)
        part.Position = position
        part.Anchored = true
        part.CanCollide = false
        part.Material = Enum.Material.Neon
        part.Color = effectColor
        part.Transparency = 0
        part.Parent = workspace
        table.insert(HitEffectParts, part)
        
        local tween = TweenService:Create(part, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = Vector3.new(effectSize, effectSize, effectSize),
            Transparency = 1
        })
        tween:Play()
        tween.Completed:Connect(function()
            part:Destroy()
            table.remove(HitEffectParts, table.find(HitEffectParts, part))
        end)
        
    elseif effectType == "Ring" then
        local part = Instance.new("Part")
        part.Size = Vector3.new(0.1, 0.1, 0.1)
        part.Position = position
        part.Anchored = true
        part.CanCollide = false
        part.Transparency = 1
        part.Parent = workspace
        
        local mesh = Instance.new("SpecialMesh")
        mesh.MeshType = Enum.MeshType.FileMesh
        mesh.MeshId = "rbxassetid://3270017"
        mesh.Scale = Vector3.new(0.1, 0.1, 0.1)
        mesh.Parent = part
        
        local decal = Instance.new("Decal")
        decal.Color3 = effectColor
        decal.Parent = part
        
        part.Color = effectColor
        part.Transparency = 0.3
        part.Material = Enum.Material.Neon
        
        table.insert(HitEffectParts, part)
        
        local tween = TweenService:Create(mesh, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Scale = Vector3.new(effectSize * 2, effectSize * 2, effectSize * 2)
        })
        local tween2 = TweenService:Create(part, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Transparency = 1
        })
        tween:Play()
        tween2:Play()
        tween2.Completed:Connect(function()
            part:Destroy()
            table.remove(HitEffectParts, table.find(HitEffectParts, part))
        end)
        
    elseif effectType == "Cross" then
        for i = 1, 4 do
            local part = Instance.new("Part")
            part.Size = Vector3.new(0.1, 0.1, effectSize)
            part.Position = position
            part.Anchored = true
            part.CanCollide = false
            part.Material = Enum.Material.Neon
            part.Color = effectColor
            part.Transparency = 0
            part.CFrame = CFrame.new(position) * CFrame.Angles(0, math.rad(90 * i), 0)
            part.Parent = workspace
            table.insert(HitEffectParts, part)
            
            local tween = TweenService:Create(part, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Size = Vector3.new(0.1, 0.1, effectSize * 3),
                Transparency = 1
            })
            tween:Play()
            tween.Completed:Connect(function()
                part:Destroy()
                table.remove(HitEffectParts, table.find(HitEffectParts, part))
            end)
        end
        
    elseif effectType == "Particles" then
        for i = 1, 8 do
            local part = Instance.new("Part")
            part.Shape = Enum.PartType.Ball
            part.Size = Vector3.new(0.3, 0.3, 0.3)
            part.Position = position
            part.Anchored = true
            part.CanCollide = false
            part.Material = Enum.Material.Neon
            part.Color = effectColor
            part.Transparency = 0
            part.Parent = workspace
            table.insert(HitEffectParts, part)
            
            local randomDir = Vector3.new(
                math.random(-100, 100) / 100,
                math.random(-100, 100) / 100,
                math.random(-100, 100) / 100
            ).Unit * effectSize
            
            local tween = TweenService:Create(part, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Position = position + randomDir,
                Size = Vector3.new(0.1, 0.1, 0.1),
                Transparency = 1
            })
            tween:Play()
            tween.Completed:Connect(function()
                part:Destroy()
                table.remove(HitEffectParts, table.find(HitEffectParts, part))
            end)
        end
    end
end

-- ══════ ANTI-AIM SYSTEM ══════
local function updateAntiAim()
    if not (Toggles.AntiAim and Toggles.AntiAim.Value) then return end
    
    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local antiAimType = Options.AntiAimType and Options.AntiAimType.Value or "Spin"
    local spinSpeed = Options.SpinSpeed and Options.SpinSpeed.Value or 10
    
    if antiAimType == "Spin" then
        SpinAngle = SpinAngle + spinSpeed
        if SpinAngle >= 360 then SpinAngle = 0 end
        
    elseif antiAimType == "Jitter" then
        SpinAngle = math.random(-180, 180)
        
    elseif antiAimType == "Random" then
        if math.random(1, 3) == 1 then
            SpinAngle = math.random(0, 360)
        end
        
    elseif antiAimType == "Reverse" then
        local camLook = camera.CFrame.LookVector
        SpinAngle = math.deg(math.atan2(camLook.X, camLook.Z)) + 180
    end
end

