-- ══════ HOOKS ══════
if hookmetamethod and checkcaller and getnamecallmethod then
    local oldNC
    oldNC = hookmetamethod(game, "__namecall", function(self, ...)
        local m = getnamecallmethod()
        local args = {...}
        
        if not checkcaller() and m == "FireServer" and self == updateCharDataRemote and isRMBPressed then
            return
        end

        if not checkcaller() and _aimPos and Toggles.SilentAim and Toggles.SilentAim.Value and passHC() then
            local tp = _aimPos
            if m == "FireServer" then
                local n = tostring(self):lower()
                if n:find("camera") or n:find("update") or n:find("mouse") or n:find("combat") or n:find("hit") then
                    for i, a in ipairs(args) do
                        if typeof(a) == "CFrame" then args[i] = CFrame.new(a.Position, tp) end
                        if typeof(a) == "Ray" then args[i] = Ray.new(a.Origin, (tp - a.Origin).Unit * a.Direction.Magnitude) end
                    end
                    return oldNC(self, unpack(args))
                end
            end
        end
        return oldNC(self, unpack(args))
    end)

    local oldIdx
    oldIdx = hookmetamethod(game, "__index", function(self, key)
        local kl = type(key) == "string" and key:lower() or ""
        if not checkcaller() and self == Mouse and _aimPos and Toggles.SilentAim and Toggles.SilentAim.Value then
            if kl == "hit" then return CFrame.new(_aimPos) end
            if kl == "target" then return _cachedTarget end
        end
        return oldIdx(self, key)
    end)
end

