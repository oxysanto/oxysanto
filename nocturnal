local function changeWeaponColor(character)
    if not (Toggles.WeaponColor and Toggles.WeaponColor.Value) then return end
    character = character or player.Character
    if not character then return end
    local color = Options.WeaponColorPicker and Options.WeaponColorPicker.Value or Color3.new(1,1,1)
    for _, v in ipairs(character:GetChildren()) do
        if v:IsA("Model") and not table.find({"Case", "Mask"}, v.Name) then
            for _, obj in v:GetDescendants() do
                if obj:IsA("BasePart") then obj.Color = color end
            end
        end
    end
end

local function changeWeaponMaterial(character)
    if not (Toggles.WeaponMaterial and Toggles.WeaponMaterial.Value) then return end
    character = character or player.Character
    if not character then return end
    local mat = Options.WeaponMaterialDrop and Enum.Material[Options.WeaponMaterialDrop.Value] or Enum.Material.SmoothPlastic
    for _, v in ipairs(character:GetChildren()) do
        if v:IsA("Model") and not table.find({"Case", "Mask"}, v.Name) then
            for _, obj in v:GetDescendants() do
                if obj:IsA("BasePart") then obj.Material = mat end
            end
        end
    end
end

local function changeCharacterAppearance(character)
    character = character or player.Character
    if not character then return end
    local colorEnabled = Toggles.CharColor and Toggles.CharColor.Value
    local matEnabled = Toggles.CharMaterial and Toggles.CharMaterial.Value
    if colorEnabled or matEnabled then
        local color = Options.CharColorPicker and Options.CharColorPicker.Value or Color3.new(1,1,1)
        local mat = Options.CharMaterialDrop and Enum.Material[Options.CharMaterialDrop.Value] or Enum.Material.SmoothPlastic
        for _, obj in ipairs(character:GetChildren()) do
            if obj:IsA("BasePart") then
                if colorEnabled then obj.Color = color end
                if matEnabled then obj.Material = mat end
            end
        end
    end
end

local function onCharacterAdded(character)
    local HRP = character:WaitForChild("HumanoidRootPart", 10)
    if not HRP then return end
    
    table.insert(_G.storage.connections, character.ChildAdded:Connect(function()
        changeWeaponColor(character)
        changeWeaponMaterial(character)
    end))

    table.insert(_G.storage.connections, HRP.ChildAdded:Connect(function(obj)
        if obj:IsA("BodyPosition") and obj.Name == "Dash" and Toggles.DashBoost and Toggles.DashBoost.Value then
            task.defer(function()
                local direction = (obj.Position - HRP.Position).Unit
                if direction.Magnitude == 0 or direction ~= direction then direction = HRP.CFrame.LookVector end
                local power = Options.DashPower and Options.DashPower.Value or 50
                local speed = Options.DashSpeed and Options.DashSpeed.Value or 4250
                obj.Position = HRP.Position + (direction * power)
                obj.P = speed
            end)
        end
    end))
    
    changeCharacterAppearance(character)
    
    local humanoid = character:WaitForChild("Humanoid", 10)
    if humanoid then
        humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
            if Toggles.WalkSpeed and Toggles.WalkSpeed.Value then
                humanoid.WalkSpeed = Options.WalkSpeedVal and Options.WalkSpeedVal.Value or 16
            end
        end)
        humanoid:GetPropertyChangedSignal("JumpPower"):Connect(function()
            if Toggles.JumpPower and Toggles.JumpPower.Value then
                humanoid.JumpPower = Options.JumpPowerVal and Options.JumpPowerVal.Value or 50
            end
        end)
    end
end

if player.Character then task.spawn(onCharacterAdded, player.Character) end
table.insert(_G.storage.connections, player.CharacterAdded:Connect(onCharacterAdded))

local function updateHumanoid()
    local humanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    if Toggles.WalkSpeed and Toggles.WalkSpeed.Value then
        humanoid.WalkSpeed = Options.WalkSpeedVal and Options.WalkSpeedVal.Value or 16
    end
    if Toggles.JumpPower and Toggles.JumpPower.Value then
        humanoid.JumpPower = Options.JumpPowerVal and Options.JumpPowerVal.Value or 50
    end
end

