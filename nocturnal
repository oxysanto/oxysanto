    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")

    if not isRMBPressed or not myHRP then
        if targetHighlight then targetHighlight.Enabled = false end
        if tracerLine then tracerLine.Visible = false end
        _aimPos = nil; _cachedTarget = nil; _smoothedPos = nil; _lockedTarget = nil
        return
    end

    local FinalTarget, TargetPart = getTargets()
    _lockedTarget = FinalTarget

    if FinalTarget and passHC() then
        _cachedTarget = TargetPart
        _aimPos = getSilentPos(TargetPart)

        if targetHighlight then
            targetHighlight.Adornee = FinalTarget.Character
            targetHighlight.Enabled = Toggles.ShowHighlight and Toggles.ShowHighlight.Value
        end

        local targetPos = _aimPos
        local screenPos = camera:WorldToViewportPoint(targetPos)

        if tracerLine then
            tracerLine.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
            tracerLine.To = Vector2.new(screenPos.X, screenPos.Y)
            tracerLine.Visible = Toggles.ShowTracer and Toggles.ShowTracer.Value
        end

        local camPos = camera.CFrame.Position
        local flatTargetPos = Vector3.new(targetPos.X, camPos.Y, targetPos.Z)
        local aimCF = CFrame.lookAt(camPos, flatTargetPos)
        local rawCameraCF = CFrame.lookAt(camPos, targetPos)
        
        -- Anti-Aim integration
        if Toggles.AntiAim and Toggles.AntiAim.Value then
            aimCF = aimCF * CFrame.Angles(0, math.rad(SpinAngle), 0)
        end

        if updateCharDataRemote and FinalTarget.Character and FinalTarget.Character.PrimaryPart then
            updateCharDataRemote:FireServer(aimCF, nil, FinalTarget.Character.PrimaryPart.CFrame, nil, myHRP.Velocity, rawCameraCF)
            
            -- Hit Effect
            if Toggles.HitEffect and Toggles.HitEffect.Value then
                local effectType = Options.HitEffectType and Options.HitEffectType.Value or "Sphere"
                createHitEffect(targetPos, effectType)
            end
        end
    else
        _aimPos = nil; _cachedTarget = nil; _smoothedPos = nil; _lockedTarget = nil
        if targetHighlight then targetHighlight.Enabled = false end
        if tracerLine then tracerLine.Visible = false end

        if myHRP and updateCharDataRemote then
            local aheadCF = myHRP.CFrame * CFrame.new(0, 0, -50)
            
            -- Anti-Aim when not targeting
            if Toggles.AntiAim and Toggles.AntiAim.Value then
                aheadCF = aheadCF * CFrame.Angles(0, math.rad(SpinAngle), 0)
            end
            
            updateCharDataRemote:FireServer(camera.CFrame, nil, aheadCF, nil, myHRP.Velocity, camera.CFrame)
        end
    end
end))

