-- Executor Detection
local function getExecutor()
    local executors = {
        {check = function() return syn and syn.protect_gui end, name = "Synapse X"},
        {check = function() return KRNL_LOADED end, name = "KRNL"},
        {check = function() return getexecutorname and getexecutorname() end, name = function() return getexecutorname() end},
        {check = function() return identifyexecutor and identifyexecutor() end, name = function() return identifyexecutor() end},
        {check = function() return fluxus end, name = "Fluxus"},
        {check = function() return Hydrogen end, name = "Hydrogen"},
        {check = function() return is_sirhurt_closure end, name = "SirHurt"},
        {check = function() return pebc_execute end, name = "ProtoSmasher"},
        {check = function() return secure_call end, name = "Sentinel"},
        {check = function() return is_electron_function end, name = "Electron"},
        {check = function() return is_synapse_function end, name = "Synapse X"},
        {check = function() return OXYGEN_LOADED end, name = "Oxygen U"},
        {check = function() return wave end, name = "Wave"},
        {check = function() return arceus end, name = "Arceus X"},
        {check = function() return delta end, name = "Delta"},
        {check = function() return Solara end, name = "Solara"},
    }
    
    for _, exec in ipairs(executors) do
        local success, result = pcall(exec.check)
        if success and result then
            if type(exec.name) == "function" then
                local nameSuccess, name = pcall(exec.name)
                if nameSuccess and name then return name end
            else
                return exec.name
            end
        end
    end
    return "Unknown Executor"
end

-- Session Yönetimi
local function destroyOldSession()
    if not _G.storage then return end
    for _,v in pairs(_G.storage.tasks or {}) do
        pcall(function() task.cancel(v) end)
    end
    for _,v in pairs(_G.storage.connections or {}) do
        pcall(function() v:Disconnect() end)
    end
    for _,v in pairs(_G.storage.objects or {}) do
        if typeof(v) == "Instance" then
            pcall(function() v:Destroy() end)
        else
            pcall(function() v:Remove() end)
        end
    end
    
    -- ESP temizle
    for _, esp in pairs(ESPObjects) do
        for _, obj in pairs(esp) do
            if typeof(obj) == "Instance" then
                pcall(function() obj:Destroy() end)
            else
                pcall(function() obj:Remove() end)
            end
        end
    end
    ESPObjects = {}
    
    -- Zoom değerlerini resetle
    player.CameraMaxZoomDistance = DEFAULT_MAX_ZOOM
    player.CameraMinZoomDistance = DEFAULT_MIN_ZOOM
    
    _G.storage = nil
end

if _G.storage then
    destroyOldSession()
end

