        Distance = Drawing.new("Text"),
        HealthBar = Drawing.new("Line"),
        HealthBarBG = Drawing.new("Line"),
        HealthText = Drawing.new("Text"),
        Box = Drawing.new("Square"),
        BoxOutline = Drawing.new("Square"),
        CornerTL = Drawing.new("Line"),
        CornerTR = Drawing.new("Line"),
        CornerBL = Drawing.new("Line"),
        CornerBR = Drawing.new("Line"),
        CornerTLH = Drawing.new("Line"),
        CornerTRH = Drawing.new("Line"),
        CornerBLH = Drawing.new("Line"),
        CornerBRH = Drawing.new("Line"),
        Chams = Instance.new("Highlight"),
    }
    
    -- Name setup
    esp.Name.Center = true
    esp.Name.Outline = true
    esp.Name.Visible = false
    
    -- Distance setup
    esp.Distance.Center = true
    esp.Distance.Outline = true
    esp.Distance.Visible = false
    
    -- Health Bar setup
    esp.HealthBar.Thickness = 2
    esp.HealthBar.Visible = false
    esp.HealthBarBG.Thickness = 4
    esp.HealthBarBG.Color = Color3.fromRGB(0, 0, 0)
    esp.HealthBarBG.Visible = false
    
    -- Health Text setup
    esp.HealthText.Center = true
    esp.HealthText.Outline = true
    esp.HealthText.Visible = false
    
    -- Box setup
    esp.Box.Thickness = 1
    esp.Box.Filled = false
    esp.Box.Visible = false
    esp.BoxOutline.Thickness = 3
    esp.BoxOutline.Filled = false
    esp.BoxOutline.Color = Color3.fromRGB(0, 0, 0)
    esp.BoxOutline.Visible = false
    
    -- Corner setup
    for _, corner in pairs({esp.CornerTL, esp.CornerTR, esp.CornerBL, esp.CornerBR, esp.CornerTLH, esp.CornerTRH, esp.CornerBLH, esp.CornerBRH}) do
        corner.Thickness = 2
        corner.Visible = false
