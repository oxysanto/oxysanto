-- ══════ YARDIMCI FONKSİYONLAR ══════
local function newTracker()
    return { smoothVel = Vector3.zero, prevVel = Vector3.zero, smoothAccel = Vector3.zero,
        history = {}, histIdx = 0, lastTick = tick(), dashActive = false, dashDirection = Vector3.zero }
end

local function getTracker(hrp)
    if not hrp or not hrp.Parent then return nil end
    if not _trackers[hrp] then _trackers[hrp] = newTracker() end
    return _trackers[hrp]
end

local function passHC()
    local hc = Options.HitChance and Options.HitChance.Value or 100
    if hc >= 100 then return true end
    if hc <= 0 then return false end
    return math.random(100) <= hc
end

local function isPartVisible(part, character)
    if not (Toggles.WallCheck and Toggles.WallCheck.Value) then return true end
    local cam = workspace.CurrentCamera
    if not cam then return false end
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.FilterDescendantsInstances = {player.Character, character}
    raycastParams.IgnoreWater = true
    
    local origin = cam.CFrame.Position
    local direction = part.Position - origin
    local result = workspace:Raycast(origin, direction, raycastParams)
    
    return result == nil
end

local function getTargetPart(character, boneOverride)
    local targetMode = boneOverride or (Options.TargetBone and Options.TargetBone.Value) or "HumanoidRootPart"
    if targetMode == "Random" then
        local eligibleParts = {}
        if character:FindFirstChild("Head") then table.insert(eligibleParts, character.Head) end
        if character:FindFirstChild("HumanoidRootPart") then table.insert(eligibleParts, character.HumanoidRootPart) end
        if character:FindFirstChild("Torso") then table.insert(eligibleParts, character.Torso) end
        if character:FindFirstChild("UpperTorso") then table.insert(eligibleParts, character.UpperTorso) end
        if #eligibleParts > 0 then
            return eligibleParts[math.random(1, #eligibleParts)]
        end
    elseif character:FindFirstChild(targetMode) then
        return character[targetMode]
    end
    return character:FindFirstChild("HumanoidRootPart")
end

local function isValid(targetPlayer, ignoreAllies)
    if targetPlayer == player then return false end
    if not (targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")) then return false end
    if not (player.Character and player.Character:FindFirstChild("HumanoidRootPart")) then return false end
    
    -- Ally check
    if ignoreAllies ~= false and isAlly(targetPlayer) then return false end
    
    local maxDist = Options.MaxDistance and Options.MaxDistance.Value or 1000
    if (player.Character.HumanoidRootPart.Position - targetPlayer.Character.HumanoidRootPart.Position).Magnitude > maxDist then return false end
    
    return true
end

local function getTargets()
    local cam = workspace.CurrentCamera
    if not cam then return nil, nil end
    local mousePos = UserInputService:GetMouseLocation()
    local myChar = player.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil, nil end

    local priorityTarget, priorityPart = nil, nil
    local fovTarget, fovPart = nil, nil
    local closestWorldDist = Options.PriorityDistance and Options.PriorityDistance.Value or 50
    local closestScreenDist = Options.FOVRadius and Options.FOVRadius.Value or 150

    for _, targetPlayer in ipairs(Players:GetPlayers()) do
        if isValid(targetPlayer) then
            local part = getTargetPart(targetPlayer.Character)
            if part then
                local worldDist = (part.Position - myHRP.Position).Magnitude
                local maxDist = Options.MaxDistance and Options.MaxDistance.Value or 1000
                if worldDist >= 5 and worldDist <= maxDist then
                    if not (Toggles.WallCheck and Toggles.WallCheck.Value) or isPartVisible(part, targetPlayer.Character) then
                        if worldDist <= closestWorldDist then
                            closestWorldDist = worldDist
                            priorityTarget = targetPlayer
                            priorityPart = part
                        end
                        local screenPos, onScreen = camera:WorldToViewportPoint(part.Position)
                        if onScreen then
                            local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                            if screenDist <= closestScreenDist then
                                closestScreenDist = screenDist
                                fovTarget = targetPlayer
                                fovPart = part
                            end
                        end
                    end
                end
            end
        end
    end

    return priorityTarget or fovTarget, priorityPart or fovPart
end

-- ══════ AIMLOCK SYSTEM ══════
local function getAimlockTarget()
    local cam = workspace.CurrentCamera
    if not cam then return nil, nil end
    local mousePos = UserInputService:GetMouseLocation()
    local myChar = player.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil, nil end

    local closestTarget, closestPart = nil, nil
    local closestScreenDist = Options.AimlockFOV and Options.AimlockFOV.Value or 200

    for _, targetPlayer in ipairs(Players:GetPlayers()) do
        if isValid(targetPlayer) then
            local aimlockBone = Options.AimlockBone and Options.AimlockBone.Value or "HumanoidRootPart"
            local part = getTargetPart(targetPlayer.Character, aimlockBone)
            if part then
                local worldDist = (part.Position - myHRP.Position).Magnitude
                local maxDist = Options.AimlockMaxDistance and Options.AimlockMaxDistance.Value or 1000
                if worldDist >= 5 and worldDist <= maxDist then
                    local wallCheck = Toggles.AimlockWallCheck and Toggles.AimlockWallCheck.Value
                    if not wallCheck or isPartVisible(part, targetPlayer.Character) then
                        local screenPos, onScreen = camera:WorldToViewportPoint(part.Position)
                        if onScreen then
                            local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                            if screenDist <= closestScreenDist then
                                closestScreenDist = screenDist
                                closestTarget = targetPlayer
                                closestPart = part
                            end
                        end
                    end
                end
            end
        end
    end

    return closestTarget, closestPart
end

local function updateAimlock()
    if not (Toggles.Aimlock and Toggles.Aimlock.Value) then
        AimlockTarget = nil
        AimlockPart = nil
        if aimlockHighlight then aimlockHighlight.Enabled = false end
        return
    end
    
    -- Check if keybind is pressed
    local aimlockKey = Options.AimlockKey
    if aimlockKey then
        isAimlockKeyPressed = aimlockKey:GetState()
    end
    
    if not isAimlockKeyPressed then
        AimlockTarget = nil
        AimlockPart = nil
        if aimlockHighlight then aimlockHighlight.Enabled = false end
        return
    end
    
    -- Sticky target - keep same target while key held
    if Toggles.AimlockSticky and Toggles.AimlockSticky.Value and AimlockTarget then
        local character = AimlockTarget.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local aimlockBone = Options.AimlockBone and Options.AimlockBone.Value or "HumanoidRootPart"
                AimlockPart = getTargetPart(character, aimlockBone)
                
                -- Update highlight
                if aimlockHighlight and Toggles.AimlockHighlight and Toggles.AimlockHighlight.Value then
                    aimlockHighlight.Adornee = character
                    aimlockHighlight.FillColor = Options.AimlockHighlightColor and Options.AimlockHighlightColor.Value or Color3.fromRGB(255, 0, 0)
                    aimlockHighlight.OutlineColor = Options.AimlockHighlightColor and Options.AimlockHighlightColor.Value or Color3.fromRGB(255, 0, 0)
                    aimlockHighlight.Enabled = true
                end
                
                -- Move camera to target
                if AimlockPart then
                    local targetPos = AimlockPart.Position
                    
                    -- Prediction for aimlock
                    if Toggles.AimlockPrediction and Toggles.AimlockPrediction.Value then
                        local hrp = character:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            local vel = hrp.AssemblyLinearVelocity or Vector3.zero
                            local predStrength = Options.AimlockPredStrength and Options.AimlockPredStrength.Value or 0.1
                            targetPos = targetPos + (vel * predStrength)
                        end
                    end
                    
                    local smoothness = Options.AimlockSmoothness and Options.AimlockSmoothness.Value or 0
                    
                    if smoothness > 0 then
                        local currentCF = camera.CFrame
                        local targetCF = CFrame.lookAt(currentCF.Position, targetPos)
                        camera.CFrame = currentCF:Lerp(targetCF, 1 - (smoothness / 100))
                    else
                        camera.CFrame = CFrame.lookAt(camera.CFrame.Position, targetPos)
                    end
                end
                
                return
            end
        end
    end
    
    -- Get new target
    local newTarget, newPart = getAimlockTarget()
    AimlockTarget = newTarget
    AimlockPart = newPart
    
    if AimlockTarget and AimlockPart then
        -- Update highlight
        if aimlockHighlight and Toggles.AimlockHighlight and Toggles.AimlockHighlight.Value then
            aimlockHighlight.Adornee = AimlockTarget.Character
            aimlockHighlight.FillColor = Options.AimlockHighlightColor and Options.AimlockHighlightColor.Value or Color3.fromRGB(255, 0, 0)
            aimlockHighlight.OutlineColor = Options.AimlockHighlightColor and Options.AimlockHighlightColor.Value or Color3.fromRGB(255, 0, 0)
            aimlockHighlight.Enabled = true
        end
        
        local targetPos = AimlockPart.Position
        
        -- Prediction for aimlock
        if Toggles.AimlockPrediction and Toggles.AimlockPrediction.Value then
            local hrp = AimlockTarget.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local vel = hrp.AssemblyLinearVelocity or Vector3.zero
                local predStrength = Options.AimlockPredStrength and Options.AimlockPredStrength.Value or 0.1
                targetPos = targetPos + (vel * predStrength)
            end
        end
        
        local smoothness = Options.AimlockSmoothness and Options.AimlockSmoothness.Value or 0
        
        if smoothness > 0 then
            local currentCF = camera.CFrame
            local targetCF = CFrame.lookAt(currentCF.Position, targetPos)
            camera.CFrame = currentCF:Lerp(targetCF, 1 - (smoothness / 100))
        else
            camera.CFrame = CFrame.lookAt(camera.CFrame.Position, targetPos)
        end
    else
        if aimlockHighlight then aimlockHighlight.Enabled = false end
    end
end

local function updateTracker(hrp)
    local t = getTracker(hrp)
    if not t then return end
    local now = tick()
    local dt = math.clamp(now - t.lastTick, 0.001, 0.1)
    t.lastTick = now
    local raw = hrp.AssemblyLinearVelocity or Vector3.zero
    local spd = raw.Magnitude
    local smoothingVal = Options.Smoothing and Options.Smoothing.Value or 50
    local a = math.clamp(1 - smoothingVal/100, 0.05, 0.9)
    t.smoothVel = t.smoothVel:Lerp(raw, a)
    
    local rawAccel = (raw - t.prevVel)/dt
    if rawAccel.Magnitude > 500 then rawAccel = rawAccel.Unit * 500 end
    t.smoothAccel = t.smoothAccel:Lerp(rawAccel, a*0.5)
    
    t.prevVel = raw
    t.histIdx = (t.histIdx % 8) + 1
    t.history[t.histIdx] = raw
    if spd > 35 then
        local dir = raw.Unit
        t.dashDirection = t.dashDirection.Magnitude < 0.1 and dir or t.dashDirection:Lerp(dir, 0.3)
        if t.dashDirection.Magnitude > 0.01 then t.dashDirection = t.dashDirection.Unit end
        t.dashActive = true
    else
        t.dashActive = false
        t.dashDirection = t.dashDirection:Lerp(Vector3.zero, 0.15)
    end
end

local function updateSelf()
    local my = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not my then _selfSmoothVel = Vector3.zero; return end
    _selfSmoothVel = _selfSmoothVel:Lerp(my.AssemblyLinearVelocity or Vector3.zero, 0.4)
end

local function getSilentPos(part)
    if not part or not part.Parent then return part and part.Position or Vector3.zero end
    local base = part.Position
    if not (Toggles.Prediction and Toggles.Prediction.Value) then _smoothedPos = base; return base end
    
    local hrp = part.Parent:FindFirstChild("HumanoidRootPart") or part
    updateTracker(hrp); updateSelf()
    local t = getTracker(hrp)
    if not t then _smoothedPos = base; return base end
    
    local eV, sV = t.smoothVel, _selfSmoothVel
    local eS, sS = eV.Magnitude, sV.Magnitude
    local rV = eV - sV; local rS = rV.Magnitude
    
    if rS < 1 and eS < 1.5 then
        _smoothedPos = _smoothedPos and _smoothedPos:Lerp(base, 0.45) or base
        return _smoothedPos
    end
    
    local predStrengthVal = Options.PredStrength and Options.PredStrength.Value or 25
    local ps = predStrengthVal/100
    local my = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    local dist = my and (my.Position - part.Position).Magnitude or 30
    
    local pingBonus = 0
    if Toggles.PingComp and Toggles.PingComp.Value then
        local currentPing = player:GetNetworkPing()
        pingBonus = math.clamp(currentPing * 1.8, 0, 0.5)
    end
    
    local ep = (ps * math.clamp(0.5+dist/60, 0.7, 1.8) * math.clamp((dist-5)/30, 0, 1)) + pingBonus
    local pv = rV * ep
    if sS > 20 then pv = pv + (-sV * ep * 0.15) end
    
    local acc = t.smoothAccel * (ep*ep*0.012)
    if acc.Magnitude > rS*0.35 then acc = acc.Unit*(rS*0.35) end
    pv = pv + acc
    
    if t.dashActive and t.dashDirection.Magnitude > 0.5 then pv = pv + t.dashDirection*(eS*ep*0.2) end
    local raw = base + pv
    local interp = math.clamp(0.45 + math.max(rS, eS)/150, 0.45, 0.95)
    _smoothedPos = _smoothedPos and _smoothedPos:Lerp(raw, interp) or raw
    return _smoothedPos
end

-- ══════ FOV CIRCLE EFFECTS ══════
local fovCircleHue = 0
local function updateFOVCircleEffects()
    local mouseLocation = UserInputService:GetMouseLocation()
    
    -- Silent Aim FOV Circle
    if Toggles.ShowFOV and Toggles.ShowFOV.Value and Toggles.SilentAim and Toggles.SilentAim.Value then
        local radius = Options.FOVRadius and Options.FOVRadius.Value or 150
        
        fovCircleOutline.Position = mouseLocation
        fovCircleOutline.Radius = radius
        
        fovCircle.Position = mouseLocation
        fovCircle.Radius = radius
        
        -- FOV Circle Effect
        local effectType = Options.FOVCircleEffect and Options.FOVCircleEffect.Value or "Static"
        
        if effectType == "Rainbow" then
            fovCircleHue = (fovCircleHue + 0.005) % 1
            fovCircle.Color = Color3.fromHSV(fovCircleHue, 1, 1)
        elseif effectType == "Pulse" then
            local pulse = (math.sin(tick() * 3) + 1) / 2
            local baseColor = Options.FOVCircleColor and Options.FOVCircleColor.Value or Color3.new(1, 1, 1)
            fovCircle.Color = baseColor:Lerp(Color3.new(1, 1, 1), pulse * 0.5)
            fovCircle.Thickness = 1.5 + pulse
        elseif effectType == "Breathing" then
            local breath = (math.sin(tick() * 2) + 1) / 2
            fovCircle.Transparency = 0.5 + breath * 0.5
        else
            fovCircle.Color = Options.FOVCircleColor and Options.FOVCircleColor.Value or Color3.new(1, 1, 1)
            fovCircle.Thickness = 1.5
            fovCircle.Transparency = 1
        end
        
        fovCircle.Visible = true
        fovCircleOutline.Visible = Toggles.FOVCircleOutline and Toggles.FOVCircleOutline.Value
    else
        fovCircle.Visible = false
        fovCircleOutline.Visible = false
    end
    
    -- Aimlock FOV Circle
    if Toggles.ShowAimlockFOV and Toggles.ShowAimlockFOV.Value and Toggles.Aimlock and Toggles.Aimlock.Value then
        local radius = Options.AimlockFOV and Options.AimlockFOV.Value or 200
        
        aimlockFovOutline.Position = mouseLocation
        aimlockFovOutline.Radius = radius
        
        aimlockFovCircle.Position = mouseLocation
        aimlockFovCircle.Radius = radius
        aimlockFovCircle.Color = Options.AimlockFOVColor and Options.AimlockFOVColor.Value or Color3.fromRGB(255, 0, 0)
        
        aimlockFovCircle.Visible = true
        aimlockFovOutline.Visible = Toggles.AimlockFOVOutline and Toggles.AimlockFOVOutline.Value
    else
        aimlockFovCircle.Visible = false
        aimlockFovOutline.Visible = false
    end
end

